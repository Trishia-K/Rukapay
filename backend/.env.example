# Local Postgres connection
DATABASE_URL="postgresql://rukatrack:password@localhost:5432/rukatrack?schema=public"

# Port the API listens on
PORT=4000

# Comma separated list of origins allowed to call the API
CORS_ORIGIN="http://localhost:5173"

# Shared secret for the fingerprint device webhook, once it's installed
BIOMETRIC_WEBHOOK_SECRET="change-me"

# Meeting invite emails - leave EMAIL_HOST blank to skip sending emails for now
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="RukaTrack <no-reply@rukapay.co.ug>"

# WebAuthn (phone/laptop fingerprint sign-in) - these three must match
# wherever the frontend is actually being opened from. Defaults below work
# for testing on your own laptop at localhost. See README for the ngrok/phone setup.
WEBAUTHN_RP_NAME="RukaTrack"
WEBAUTHN_RP_ID="localhost"
WEBAUTHN_ORIGIN="http://localhost:5173"

# Restricts fingerprint registration and sign-in to specific IP addresses -
# this is what actually stops someone signing in from home. Leave blank
# while testing locally (nothing to restrict yet); fill in once RukaTrack
# is deployed somewhere with a real address. Comma separated for multiple.
# Find your office's IP by visiting whatismyip.com from an office computer.
OFFICE_ALLOWED_IPS=""
